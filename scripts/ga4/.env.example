# Google Analytics 4 プロパティID（数字のみ）
# 確認方法: Google Analytics > 管理 > プロパティ設定
GA4_PROPERTY_ID=123456789

# Google Cloud サービスアカウントキーのパス（絶対パス）
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Google Search Console サイトURL
GSC_SITE_URL=sc-domain:saharasabaka.vercel.app

# Slack Bot Token（デイリーレポート用）
# 取得方法: https://api.slack.com/apps > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack チャンネルID
# チャンネル名ではなく、チャンネルIDを使用（右クリック > チャンネル詳細からコピー）
SLACK_CHANNEL=C0123456789

# Slack Webhook URL（失敗通知用、オプション）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
